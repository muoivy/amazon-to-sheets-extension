{
  "manifest_version": 3,
  "name": "Product To Google Sheets",
  "version": "1.0.0",
  "description": "Scrape supported retailer product data and send it to Google Sheets via Google Apps Script.",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://*.amazon.com/*",
    "*://*.instacart.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "action": {
    "default_title": "Product To Sheets",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://*.instacart.com/*"
      ],
      "js": [
        "scrapers/shared.js",
        "scrapers/amazon.js",
        "scrapers/instacart.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
